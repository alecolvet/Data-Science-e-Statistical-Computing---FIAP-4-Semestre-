def one_hot_share(df, col, idcol='customer_id'):
    ct = pd.crosstab(df[idcol], df[col])
    ct = ct.div(ct.sum(axis=1), axis=0).fillna(0.0)
    ct.columns = [f"{col.lower()}_share_{c}" for c in ct.columns]
    return ct

mix_cat = one_hot_share(df, 'category')
mix_channel = one_hot_share(df, 'channel')
mix_ship = one_hot_share(df, 'shipping_method')

cust_features = (customer
                 .merge(mix_cat, left_on='customer_id', right_index=True, how='left')
                 .merge(mix_channel, left_on='customer_id', right_index=True, how='left')
                 .merge(mix_ship, left_on='customer_id', right_index=True, how='left')
                 .fillna(0.0))

