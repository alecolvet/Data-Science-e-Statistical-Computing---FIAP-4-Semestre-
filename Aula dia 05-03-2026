from sklearn.cluster import KMeans
from sklearn.metrics import silhouette_score, silhouette_samples
import numpy as np
import pandas as pd

sil_scores = []
for k in range(2, 9):
    km = KMeans(n_clusters=k, n_init=10, random_state=42)
    labels = km.fit_predict(Xp[:, :10])
    sil = silhouette_score(Xp[:, :10], labels)
    sil_scores.append((k, sil))

sil_df = pd.DataFrame(sil_scores, columns=["k","silhouette"]).sort_values("k")
sil_df


fig = plt.figure()
plt.plot(sil_df['k'], sil_df['silhouette'], marker='o')
plt.xlabel("k")
plt.ylabel("Silhouette médio")
plt.title("Silhouette por k (PCA 10 PCs)")
plt.show()


best_k = int(sil_df.iloc[sil_df['silhouette'].idxmax()]['k'])
km = KMeans(n_clusters=best_k, n_init=10, random_state=42)
labels = km.fit_predict(Xp[:, :10])
sil_vals = silhouette_samples(Xp[:, :10], labels)
avg_sil = sil_vals.mean()
print("k escolhido:", best_k, "| silhouette médio:", round(avg_sil, 3))

# Gráfico de silhueta
fig = plt.figure()
y_lower = 10
for i in range(best_k):
    ith_sil_vals = sil_vals[labels == i]
    ith_sil_vals.sort()
    size_i = ith_sil_vals.shape[0]
    y_upper = y_lower + size_i
    plt.fill_betweenx(np.arange(y_lower, y_upper), 0, ith_sil_vals)
    plt.text(-0.05, y_lower + 0.5*size_i, str(i))
    y_lower = y_upper + 10

plt.axvline(avg_sil, linestyle="--")
plt.xlabel("Coeficiente de Silhueta")
plt.ylabel("Clusters")
plt.title(f"Gráfico de Silhueta — k={best_k}")
plt.show()


